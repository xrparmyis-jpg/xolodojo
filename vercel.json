{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "devCommand": "vite",
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api?p=$1"
    },
    {
      "source": "/((?!api/)(?!_vercel/).*)",
      "destination": "/index.html"
    }
  ]
}
