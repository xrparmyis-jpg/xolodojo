# Coming soon gate (Vercel Edge Middleware — not a VITE_ var).
# Set to 1 in Vercel Production to show the landing page on your custom domain; 0 or unset for the full site.
# Must be exactly "1" — other values (including "true") are treated as off.
# *.vercel.app URLs always bypass the gate so the default deployment URL stays usable for preview.
# COMING_SOON_MODE=0

# Mapbox Access Token
# Get your token from https://account.mapbox.com/access-tokens/
# Copy this file to .env.local and add your actual token
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# Mapbox Username
VITE_MAPBOX_USERNAME=your_mapbox_username

# Mapbox Style ID
VITE_MAPBOX_STYLE_ID=your_mapbox_style_id

# Canonical site origin, no trailing slash. Used for Open Graph / social link previews (og:url, og:image).
# Set in Vercel to your public URL (custom domain or *.vercel.app) so shared links show the right image.
# VITE_SITE_URL=https://xolodojo.vercel.app
# Optional: image path under /public. Default: /team/Cryptonite.jpg
# VITE_OG_IMAGE_PATH=/team/Cryptonite.jpg

# Public site URL (used in Supabase auth email redirect links)
# Example local: http://localhost:5173  Production: https://your-domain.com
# Vercel: set in Production to your canonical URL (custom domain or xolodojo.vercel.app).
# Must also match Supabase Dashboard → Auth → URL Configuration (Site URL + Redirect URLs).
APP_PUBLIC_URL=http://localhost:5173

# Resend — forgot-username emails only (server API).
# Signup verification and password reset are sent by Supabase Auth; configure Resend there:
# Supabase Dashboard → Authentication → SMTP Settings (smtp.resend.com, user: resend, pass: API key).
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=XoloDojo <noreply@yourdomain.com>

# Supabase (frontend — Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Supabase (backend API — server only, never expose service role to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: email/OAuth redirect for Supabase Auth (must match Supabase Dashboard → Auth → URL Configuration)
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:5173/auth/callback

# API Configuration
# For local development, API routes are served from /api
# For production, set this to your backend API URL
VITE_API_BASE_URL=

# XRPL Wallet (Xaman)
# Create an API key at https://apps.xumm.dev
VITE_XAMAN_API_KEY=
# Optional: persist Xaman session to recover mobile redirect flow automatically
# Set to false to disable persistence (default behavior is true)
VITE_XAMAN_REMEMBER_JWT=true
# Optional: must exactly match a Redirect URL in https://apps.xumm.dev (Xaman app settings).
# Production mobile profile returns only — localhost uses /?xaman_return=1 automatically.
# VITE_XAMAN_REDIRECT_URL=https://xolodojo.vercel.app/profile?xaman_return=1
# Local dev: register ALL of these redirect URLs in the Xaman Developer Console:
#   http://localhost:5173/?xaman_return=1
#   http://localhost:5173/?xaman_flow=desktop
# Production also register:
#   https://your-domain/profile?xaman_return=1
#   https://your-domain/?xaman_return=1
#   https://your-domain/?xaman_flow=desktop
# VITE_SITE_URL=https://xolodojo.vercel.app
# VITE_XAMAN_DESKTOP_HANDOFF_URL=https://xolodojo.vercel.app

# WalletConnect (for Add Another Wallet selector)
# Create a project ID at https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=
# Optional: set true only when intentionally testing browser-injected wallets (MetaMask, Trust, etc.)
# Default behavior keeps WalletConnect modal focused on QR/recents/all-wallets flows.
VITE_WC_ENABLE_INJECTED=false
# Optional EVM chain IDs to include in WalletConnect session proposals (comma-separated)
# Default app behavior is mainnet-only for broad mobile wallet compatibility
# Example for multi-chain: VITE_WC_CHAIN_IDS=1,137,42161,10,8453
VITE_WC_CHAIN_IDS=1

# Joey Wallet dedicated connection flow (separate from WalletConnect modal)
VITE_JOEY_PROJECT_ID=
